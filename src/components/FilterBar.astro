---
/**
 * 태그 필터 바 (SPEC §5) — 클라이언트 사이드, URL 쿼리 동기화.
 * 그룹 내 OR, 그룹 간 AND. 카드는 [data-specimen-card]의 data-* 속성으로 매칭.
 */
type FacetKey = 'category' | 'interaction' | 'stack';
interface Facet {
  key: FacetKey;
  label: string;
  values: [string, number][];
}
interface Props {
  facets: Facet[];
  total: number;
}
const { facets, total } = Astro.props;
---

<section data-filter-bar class="border-b border-line py-6">
  <div class="flex items-baseline justify-between pb-4">
    <p class="font-mono text-[11px] uppercase tracking-widest text-muted">Filter</p>
    <p class="font-mono text-xs text-muted">
      <button type="button" data-clear class="hidden pr-3 text-accent hover:underline">
        필터 해제 ×
      </button>
      <span data-visible-count class="text-cream">{total}</span> / {total}
    </p>
  </div>

  <div class="flex flex-col gap-3">
    {
      facets.map((f) => (
        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-2">
          <span class="w-full shrink-0 font-mono text-[11px] uppercase tracking-widest text-muted md:w-28">
            {f.label}
          </span>
          {f.values.map(([v, n]) => (
            <button
              type="button"
              data-chip
              data-group={f.key}
              data-value={v}
              aria-pressed="false"
              class="cursor-pointer border border-line bg-transparent px-2.5 py-1 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-cream aria-pressed:border-accent aria-pressed:text-accent"
            >
              {v} <span class="opacity-55">{n}</span>
            </button>
          ))}
        </div>
      ))
    }
  </div>

  <p data-empty class="hidden pt-6 font-mono text-sm text-muted">
    이 조합의 표본은 아직 채집되지 않았습니다.
  </p>
</section>

<script>
  const GROUPS = ['category', 'interaction', 'stack'] as const;
  type Group = (typeof GROUPS)[number];

  const bar = document.querySelector<HTMLElement>('[data-filter-bar]');
  const cards = document.querySelectorAll<HTMLElement>('[data-specimen-card]');
  if (bar && cards.length) {
    const chips = bar.querySelectorAll<HTMLButtonElement>('[data-chip]');
    const countEl = bar.querySelector<HTMLElement>('[data-visible-count]');
    const emptyEl = bar.querySelector<HTMLElement>('[data-empty]');
    const clearBtn = bar.querySelector<HTMLButtonElement>('[data-clear]');

    // URL 쿼리 → 초기 상태 (?interaction=cursor-fx,morphing&stack=webgl)
    const params = new URLSearchParams(location.search);
    const state = new Map<Group, Set<string>>(
      GROUPS.map((g) => [g, new Set(params.get(g)?.split(',').filter(Boolean) ?? [])])
    );

    const apply = () => {
      const active = GROUPS.some((g) => state.get(g)!.size > 0);
      chips.forEach((ch) => {
        const on = state.get(ch.dataset.group as Group)!.has(ch.dataset.value ?? '');
        ch.setAttribute('aria-pressed', String(on));
      });
      let visible = 0;
      cards.forEach((card) => {
        const ok = GROUPS.every((g) => {
          const sel = state.get(g)!;
          if (!sel.size) return true;
          return (card.dataset[g] ?? '').split(' ').some((v) => sel.has(v));
        });
        card.classList.toggle('hidden', !ok);
        if (ok) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
      emptyEl?.classList.toggle('hidden', visible > 0);
      clearBtn?.classList.toggle('hidden', !active);
      // URL 동기화 — 필터 상태가 공유 가능한 링크가 된다
      const q = new URLSearchParams();
      GROUPS.forEach((g) => {
        const sel = [...state.get(g)!];
        if (sel.length) q.set(g, sel.join(','));
      });
      const qs = q.toString();
      history.replaceState(null, '', qs ? `${location.pathname}?${qs}` : location.pathname);
    };

    chips.forEach((ch) => {
      ch.addEventListener('click', () => {
        const sel = state.get(ch.dataset.group as Group)!;
        const v = ch.dataset.value ?? '';
        if (sel.has(v)) sel.delete(v);
        else sel.add(v);
        apply();
      });
    });
    clearBtn?.addEventListener('click', () => {
      GROUPS.forEach((g) => state.get(g)!.clear());
      apply();
    });

    apply();
  }
</script>
