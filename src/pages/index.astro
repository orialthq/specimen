---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FilterBar from '../components/FilterBar.astro';
import { formatDate, orderSpecimens, specimenNo, withBase } from '../lib/specimens';

const specimens = await getCollection('specimens');
const ordered = orderSpecimens(specimens);

// 필터 파셋 — 빈도순, 실제 존재하는 값만
const countBy = (vals: string[]): [string, number][] => {
  const m = new Map<string, number>();
  for (const v of vals) m.set(v, (m.get(v) ?? 0) + 1);
  return [...m.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
};
const facets = [
  { key: 'category' as const, label: 'category', values: countBy(ordered.map((s) => s.data.category)) },
  {
    key: 'interaction' as const,
    label: 'interaction',
    values: countBy(ordered.flatMap((s) => s.data.interaction)),
  },
  { key: 'stack' as const, label: 'stack', values: countBy(ordered.flatMap((s) => s.data.stack)) },
];
---

<Base>
  <main class="mx-auto max-w-6xl px-6 py-16">
    <header class="border-b border-line pb-8">
      <p class="font-mono text-sm text-muted">ORIALT ARCHIVE</p>
      <h1 class="font-display text-5xl text-cream md:text-7xl">Specimen</h1>
      <p class="mt-4 max-w-xl text-muted">
        웹 디자인 레퍼런스를 표본으로 수집하고 해부하는 아카이브.
      </p>
    </header>

    <FilterBar facets={facets} total={ordered.length} />

    <section class="py-12">
      <div class="grid gap-8 md:grid-cols-2">
        {
          ordered.map(
            (s, idx) =>
              s.data.snippet && (
                <article
                  class="border border-line transition-colors hover:border-accent"
                  data-specimen-card
                  data-category={s.data.category}
                  data-interaction={s.data.interaction.join(' ')}
                  data-stack={s.data.stack.join(' ')}
                >
                  {/* 그리드에선 앰비언트 모션만(포인터 차단) — 클릭 시 해부 페이지 */}
                  <a
                    href={withBase(`/s/${s.id}/`)}
                    class="block"
                    aria-label={`${s.data.title} — 해부 페이지 열기`}
                  >
                    <iframe
                      data-src={`${withBase(s.data.snippet)}?auto=1`}
                      title={`${s.data.title} — 재현 스니펫`}
                      loading="lazy"
                      tabindex="-1"
                      class="pointer-events-none aspect-video w-full bg-base"
                    ></iframe>
                  </a>
                  <div class="border-t border-line p-4">
                    <div class="flex items-baseline justify-between gap-2">
                      <p class="font-mono text-xs text-muted">
                        <span class="text-accent">{specimenNo(idx)}</span> · 채집{' '}
                        {formatDate(s.data.collectedAt)} · {s.data.curator}
                      </p>
                      <div class="flex gap-1" aria-label="추출 팔레트">
                        {s.data.palette.map((hex) => (
                          <span
                            class="inline-block h-3 w-5 border border-line"
                            style={`background:${hex}`}
                            title={hex}
                          />
                        ))}
                      </div>
                    </div>
                    <h2 class="mt-2 font-display text-2xl text-cream">
                      <a class="hover:text-accent" href={withBase(`/s/${s.id}/`)}>
                        {s.data.title}
                      </a>
                    </h2>
                    <p class="mt-2 font-mono text-xs text-muted">
                      {s.data.interaction.join(' · ')}
                    </p>
                    <p class="mt-3 font-mono text-xs">
                      <a class="text-accent hover:underline" href={withBase(`/s/${s.id}/`)}>
                        해부 노트 →
                      </a>
                      <span class="text-muted"> · </span>
                      <a
                        class="text-muted hover:underline"
                        href={withBase(s.data.snippet)}
                        target="_blank"
                        rel="noopener"
                      >
                        전체 화면 ↗
                      </a>
                    </p>
                  </div>
                </article>
              )
          )
        }
      </div>
      <p class="pt-8 font-mono text-xs text-muted">
        채집된 표본 <span class="text-accent">{specimens.length}</span>건 · 재현 스니펫은 원본의
        코드가 아니라 기법을 추출한 자체 재현물.
      </p>
    </section>
  </main>
</Base>

<script>
  // 표본 25+건의 라이브 iframe을 전부 돌리면 rAF가 겹쳐 저사양에서 죽는다.
  // 뷰포트 ±40% 안의 카드만 로드하고, 멀어지면 언로드해 rAF를 정지시킨다.
  const frames = document.querySelectorAll<HTMLIFrameElement>('iframe[data-src]');
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        const f = e.target as HTMLIFrameElement;
        const src = f.dataset.src;
        if (!src) continue;
        if (e.isIntersecting) {
          if (!f.getAttribute('src')) f.src = src;
        } else if (f.getAttribute('src')) {
          f.removeAttribute('src'); // about:blank — 데모의 rAF/캔버스 해제
        }
      }
    },
    { rootMargin: '40% 0px' }
  );
  frames.forEach((f) => io.observe(f));
</script>
